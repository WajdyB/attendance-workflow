generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  description String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model Department {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]   // One department can have many users
}

model User {
  id            String   @id @default(uuid())
  authId        String   @unique
  roleId        String
  firstName     String
  lastName      String
  birthdate     DateTime
  phone         String
  address       String
  personalEmail String   @unique
  workEmail     String   @unique
  jobTitle      String
  bankName      String
  cnssNumber    String   @unique  
  accountStatus String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  avatarUrl     String?
  // Relations
  role          Role         @relation(fields: [roleId], references: [id])
  departmentId  String?                  // NEW: Foreign key to Department
  department    Department?   @relation(fields: [departmentId], references: [id])
  documents     Document[]               // NEW: User can have many documents
}
enum DocumentCategory {
  HR
  CONTRACT
  PAYROLL
  REQUEST_ATTACHMENT
  OTHER 
}
model Document {
  id          String   @id @default(uuid())
  userId      String                    // Foreign key to User
  title       String?
  fileUrl     String?
  fileType    String?
  fileSize    Int?
  category    DocumentCategory
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])    // For faster queries
}